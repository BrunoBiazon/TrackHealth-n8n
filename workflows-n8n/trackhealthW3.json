    {
      "parameters": {
        "jsCode": "const textoOriginal = $input.first().json.choices[0].message.content;\n\nconst textoLimpo = textoOriginal\n  .replace(/[#_*`~]/g, '') \n  .replace(/\\\\n/g, '\\n');  \n\nreturn {\n  texto_para_telegram: textoLimpo\n};"
      },
