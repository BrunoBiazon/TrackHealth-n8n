    {
      "parameters": {
        "jsCode": "const dataCorteStr = $('Code in JavaScript').item.json.data_corte; \nconst [cd, cm, cy] = dataCorteStr.split('/');\nconst corteFormatado = parseInt(`${cy}${cm}${cd}`);\n\nconst todosDados = $items();\nconst resultado = todosDados.filter(item => {\n  const chaves = [\"Data Cardio\", \"Data exercício \", \"Data sono \", \"Data peso\", \"Data hidratação \", \"Data Medicação \"];\n  \n  const chaveEncontrada = chaves.find(k => item.json.hasOwnProperty(k));\n  \n\n  if (!chaveEncontrada) return true; \n  \n  const dataStr = item.json[chaveEncontrada];\n  if (!dataStr) return true;\n  \n  const [d, m, y] = dataStr.split('/');\n  const dataFormatada = parseInt(`${y}${m}${d}`);\n  \n  return dataFormatada >= corteFormatado;\n});\n\nreturn {\n  json: {\n    periodo: \"Analise de performance\",\n    total_registros: resultado.length,\n    registros: resultado.map(i => i.json)\n  }\n};"
      },
